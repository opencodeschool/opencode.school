#!/usr/bin/env bash
set -e

# Set Cloudflare secrets for GitHub Actions
# Usage: script/setup-secrets

if [ -z "$CLOUDFLARE_API_TOKEN" ]; then
  echo "Error: CLOUDFLARE_API_TOKEN environment variable is not set"
  echo "Set it with: export CLOUDFLARE_API_TOKEN=your_token_here"
  exit 1
fi

if [ -z "$CLOUDFLARE_ACCOUNT_ID" ]; then
  echo "Error: CLOUDFLARE_ACCOUNT_ID environment variable is not set"
  echo "Set it with: export CLOUDFLARE_ACCOUNT_ID=your_account_id_here"
  exit 1
fi

echo "Setting CLOUDFLARE_API_TOKEN secret..."
echo "$CLOUDFLARE_API_TOKEN" | gh secret set CLOUDFLARE_API_TOKEN

echo "Setting CLOUDFLARE_ACCOUNT_ID secret..."
echo "$CLOUDFLARE_ACCOUNT_ID" | gh secret set CLOUDFLARE_ACCOUNT_ID

echo "✓ Secrets configured successfully"
