---
import "../styles/main.css";
import { getCollection } from "astro:content";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Learn to use OpenCode, the free and open-source AI coding agent." } = Astro.props;

const lessons = (await getCollection("lessons")).sort((a, b) => a.data.order - b.data.order);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} - OpenCode School</title>
    <script is:inline>
      if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
        document.documentElement.classList.add("dark");
      }
      window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
        document.documentElement.classList.toggle("dark", e.matches);
      });
    </script>
  </head>
  <body class="min-h-screen">
    <div class="lg:flex">
      <!-- Mobile header -->
      <header class="lg:hidden flex items-center justify-between p-4 border-b border-gray-200 dark:border-gray-800">
        <a href="/" class="font-mono font-bold text-lg">OpenCode School</a>
        <button
          id="menu-toggle"
          class="p-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800"
          aria-label="Toggle navigation"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </header>

      <!-- Sidebar -->
      <nav
        id="sidebar"
        class="hidden lg:block w-72 shrink-0 border-r border-gray-200 dark:border-gray-800 h-screen sticky top-0 overflow-y-auto p-6"
      >
        <a href="/" class="block font-mono font-bold text-lg mb-6">OpenCode School</a>
        <ol class="space-y-1">
          {lessons.map((lesson) => {
            const href = `/lessons/${lesson.data.slug}`;
            const isActive = currentPath === href || currentPath === `${href}/`;
            const isStub = lesson.body?.trim() === "Coming soon.";
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    "block px-3 py-1.5 rounded-md text-sm transition-colors",
                    isActive
                      ? "bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300 font-medium"
                      : "text-gray-600 hover:text-gray-900 hover:bg-gray-50 dark:text-gray-400 dark:hover:text-gray-200 dark:hover:bg-gray-900",
                    isStub && "opacity-50",
                  ]}
                >
                  <span class="text-gray-400 dark:text-gray-600 mr-1.5">{lesson.data.order}.</span>
                  {lesson.data.title}
                </a>
              </li>
            );
          })}
        </ol>
        <div class="mt-6 pt-4 border-t border-gray-200 dark:border-gray-800">
          <a
            href="/glossary"
            class:list={[
              "block px-3 py-1.5 rounded-md text-sm transition-colors",
              currentPath === "/glossary" || currentPath === "/glossary/"
                ? "bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300 font-medium"
                : "text-gray-600 hover:text-gray-900 hover:bg-gray-50 dark:text-gray-400 dark:hover:text-gray-200 dark:hover:bg-gray-900",
            ]}
          >
            Glossary
          </a>
        </div>
        <div class="mt-6 pt-4 border-t border-gray-200 dark:border-gray-800 text-xs text-gray-400 dark:text-gray-600">
          <a href="https://github.com/zeke/opencode.school" class="hover:text-gray-600 dark:hover:text-gray-400">
            GitHub
          </a>
        </div>
      </nav>

      <!-- Main content -->
      <main class="flex-1 min-w-0 p-6 lg:p-12 max-w-3xl">
        <slot />
      </main>
    </div>

    <script is:inline>
      // Mobile menu toggle
      const toggle = document.getElementById("menu-toggle");
      const sidebar = document.getElementById("sidebar");
      if (toggle && sidebar) {
        toggle.addEventListener("click", () => {
          sidebar.classList.toggle("hidden");
          if (!sidebar.classList.contains("hidden")) {
            sidebar.classList.add("fixed", "inset-0", "z-50", "bg-white", "dark:bg-gray-950");
            sidebar.classList.remove("lg:block");
          } else {
            sidebar.classList.remove("fixed", "inset-0", "z-50", "bg-white", "dark:bg-gray-950");
            sidebar.classList.add("lg:block");
          }
        });
      }

      // Progress tracking
      window.school = {
        getStudentId() {
          return localStorage.getItem("studentId");
        },

        setStudentId(id) {
          localStorage.setItem("studentId", id);
        },

        getCachedProgress() {
          try {
            return JSON.parse(localStorage.getItem("progress") || "null");
          } catch { return null; }
        },

        setCachedProgress(progress) {
          localStorage.setItem("progress", JSON.stringify(progress));
        },

        isLessonComplete(slug) {
          const progress = this.getCachedProgress();
          return progress?.completedLessons?.includes(slug) || false;
        },

        async enroll() {
          const res = await fetch("/api/enroll", { method: "POST" });
          if (!res.ok) throw new Error("Enrollment failed");
          const data = await res.json();
          this.setStudentId(data.studentId);
          this.setCachedProgress(data.progress);
          return data;
        },

        async fetchProgress() {
          const studentId = this.getStudentId();
          if (!studentId) return null;
          const res = await fetch(`/api/progress/${studentId}`);
          if (!res.ok) return null;
          const progress = await res.json();
          this.setCachedProgress(progress);
          return progress;
        },

        async markComplete(lessonSlug) {
          const studentId = this.getStudentId();
          if (!studentId) return null;
          const res = await fetch(`/api/progress/${studentId}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ lessonSlug }),
          });
          if (!res.ok) return null;
          const progress = await res.json();
          this.setCachedProgress(progress);
          return progress;
        },

        updateAllCheckmarks() {
          document.querySelectorAll("[data-lesson-slug]").forEach((el) => {
            const slug = el.getAttribute("data-lesson-slug");
            const checkEl = el.querySelector(".lesson-check");
            const numEl = el.querySelector(".lesson-number");
            const complete = this.isLessonComplete(slug);
            if (checkEl) checkEl.textContent = complete ? "\u2713" : "";
            if (numEl) numEl.style.display = complete ? "none" : "";
          });
        },
      };

      // Handle ?sid= param: save student ID from URL and clean up
      (function() {
        const params = new URLSearchParams(window.location.search);
        const sid = params.get("sid");
        if (sid) {
          window.school.setStudentId(sid);
          // Remove ?sid= from URL without reload
          const url = new URL(window.location);
          url.searchParams.delete("sid");
          window.history.replaceState({}, "", url.pathname + url.search);
          // Fetch progress for this student
          window.school.fetchProgress().then(() => {
            window.school.updateAllCheckmarks();
          });
        } else if (window.school.getStudentId()) {
          // Already enrolled — sync progress on page load
          window.school.fetchProgress().then(() => {
            window.school.updateAllCheckmarks();
          });
        }
      })();
    </script>
  </body>
</html>
