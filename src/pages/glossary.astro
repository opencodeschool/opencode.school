---
export const prerender = true;

import Base from "../layouts/Base.astro";
import { readFile } from "node:fs/promises";
---

<Base title="Glossary" description="Definitions of common terms used in OpenCode School.">
  <div class="mb-6">
    <a href="/" class="text-sm text-gray-500 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
      &larr; All lessons
    </a>
  </div>

  <header class="mb-8">
    <h1 class="text-3xl font-bold">Glossary</h1>
    <p class="text-gray-600 dark:text-gray-400 mt-2">Definitions of common terms used in OpenCode School.</p>
  </header>

  <article class="prose dark:prose-invert max-w-none" set:html={await (async () => {
    const { marked } = await import("marked");
    const raw = await readFile("lessons/glossary.md", "utf-8");
    const body = raw.replace(/^---[\s\S]*?---\n/, "");
    return marked(body);
  })()} />
</Base>
