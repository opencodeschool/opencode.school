export const prerender = true;

import Base from "../../layouts/Base.astro";
import { localePath } from "../../i18n/locales";
import { t } from "../../i18n/ui";
import { marked } from "marked";
import glossaryRaw from "../../../lessons/glossary.md?raw";

const locale = "pt" as const;

const renderer = new marked.Renderer();
renderer.heading = function ({ text, depth }) {
  const slug = text.toLowerCase().replace(/[^\w]+/g, "-").replace(/(^-|-$)/g, "");
  return `<h${depth} id="${slug}"><a href="#${slug}" class="heading-anchor">${text}</a></h${depth}>`;
};

const body = glossaryRaw.replace(/^---[\s\S]*?---\n/, "");
const html = await marked(body, { renderer });
---

<Base title={t("glossary.title", locale) as string} description={t("glossary.subtitle", locale) as string} locale={locale}>
  <div class="mb-6">
    <a href={localePath("/", locale)} class="text-sm text-gray-500 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
      &larr; {t("nav.allLessons", locale)}
    </a>
  </div>

  <header class="mb-8">
    <h1 class="text-3xl font-bold">{t("glossary.title", locale)}</h1>
    <p class="text-gray-600 dark:text-gray-400 mt-2">{t("glossary.subtitle", locale)}</p>
  </header>

  <article class="prose dark:prose-invert max-w-none" set:html={html} />
</Base>
