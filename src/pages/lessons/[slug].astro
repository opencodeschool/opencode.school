---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const lessons = await getCollection("lessons");
  return lessons.map((lesson) => ({
    params: { slug: lesson.data.slug },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const { Content } = await render(lesson);

const allLessons = (await getCollection("lessons")).sort((a, b) => a.data.order - b.data.order);
const currentIndex = allLessons.findIndex((l) => l.data.slug === lesson.data.slug);
const prev = currentIndex > 0 ? allLessons[currentIndex - 1] : null;
const next = currentIndex < allLessons.length - 1 ? allLessons[currentIndex + 1] : null;
---

<Base title={lesson.data.title} description={lesson.data.description}>
  <div class="mb-6">
    <a href="/" class="text-sm text-gray-500 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
      &larr; All lessons
    </a>
  </div>

  <header class="mb-8">
    <p class="text-sm font-mono text-gray-400 dark:text-gray-600 mb-1">Lesson {lesson.data.order}</p>
    <h1 class="text-3xl font-bold">{lesson.data.title}</h1>
    <p class="text-gray-600 dark:text-gray-400 mt-2">{lesson.data.description}</p>
  </header>

  <article class="prose dark:prose-invert max-w-none">
    <Content />
  </article>

  <nav class="mt-12 pt-6 border-t border-gray-200 dark:border-gray-800 flex justify-between gap-4">
    {prev ? (
      <a
        href={`/lessons/${prev.data.slug}`}
        class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        &larr; {prev.data.title}
      </a>
    ) : <span />}
    {next ? (
      <a
        href={`/lessons/${next.data.slug}`}
        class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors ml-auto"
      >
        {next.data.title} &rarr;
      </a>
    ) : <span />}
  </nav>
</Base>
