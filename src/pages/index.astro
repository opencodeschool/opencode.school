---
export const prerender = true;

import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const lessons = (await getCollection("lessons")).sort((a, b) => a.data.order - b.data.order);
---

<Base title="Home">

  <!-- Student ID card: always at top, shown once enrolled -->
  <div id="student-id-card" class="hidden mb-8" style="max-width:420px">
    <div class="theme-card-band rounded-2xl overflow-hidden shadow-2xl" style="aspect-ratio:85.6/54">
      <div class="flex flex-col justify-between h-full px-7 py-5">
        <p class="text-xs font-mono uppercase tracking-[0.3em] opacity-80">OpenCode Student ID</p>
        <p id="student-id-display" class="text-2xl font-mono font-bold tracking-tight"></p>
      </div>
    </div>
  </div>

  <!-- Page header: hidden once enrolled -->
  <div id="page-header" class="mb-8">
    <p class="text-xl text-gray-700 dark:text-gray-300 leading-relaxed">
      OpenCode School is a free, self-paced course for learning <a href="https://opencode.ai" class="theme-link underline">OpenCode</a>, the open-source AI coding agent.
    </p>
  </div>

  <!-- Enrolled: lesson list -->
  <div id="enrolled-section" class="hidden mb-12">
    <h2 class="text-sm font-mono uppercase tracking-wider text-gray-500 dark:text-gray-500 mb-4">Lessons</h2>

    <ol class="divide-y divide-gray-200 dark:divide-stone-800">
      {lessons.map((lesson) => {
        const isStub = lesson.body?.trim() === "Coming soon.";
        const href = `/lessons/${lesson.data.slug}`;
        return (
          <li data-lesson-slug={lesson.data.slug} data-lesson-stub={isStub ? "true" : "false"}>
            <div class="lesson-row flex flex-col gap-3 py-3 transition-colors sm:flex-row sm:items-center sm:justify-between">
              <a
                href={href}
                class="lesson-link group flex min-w-0 items-center gap-3"
              >
                <span
                  class="lesson-status flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-gray-300 bg-gray-100/70 text-white dark:border-stone-700 dark:bg-stone-900/70"
                  aria-hidden="true"
                >
                  <span class="lesson-status-dot h-2 w-2 rounded-full bg-gray-400 dark:bg-stone-500"></span>
                  <span class="lesson-check hidden h-full w-full items-center justify-center text-xs font-bold leading-none">&#10003;</span>
                </span>
                <div class="min-w-0">
                  <h3 class:list={[
                    "lesson-title font-medium transition-colors",
                    isStub && "text-gray-400 dark:text-gray-600",
                  ]}>
                    {lesson.data.title}
                    {isStub && <span class="ml-2 text-xs font-normal text-gray-400 dark:text-gray-600">(coming soon)</span>}
                  </h3>
                  <p class="lesson-description mt-0.5 text-sm text-gray-500 dark:text-gray-500">{lesson.data.description}</p>
                </div>
              </a>
              <a
                href={href}
                class="lesson-cta theme-button hidden shrink-0 rounded-lg px-3 py-2 text-center font-mono text-sm"
              >
                Continue
              </a>
            </div>
          </li>
        );
      })}
    </ol>
  </div>

  <!-- Not enrolled: enrollment widget -->
  <div id="not-enrolled-section" class="mb-12">
    <div id="enroll-step-button" class="py-8">
      <button
        type="button"
        id="enroll-button"
        class="theme-button cursor-pointer rounded-lg px-10 py-4 font-mono text-lg disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Enroll in OpenCode School &rarr;
      </button>
      <p class="text-sm text-gray-500 dark:text-stone-500 mt-4">
        Free forever. No account required. No personal data collected.
      </p>
    </div>

    <div id="enroll-step-color" class="hidden">
      <p id="color-picker-copy" class="text-sm text-gray-600 dark:text-stone-400 mb-4">Choose a color for your student ID card and site theme.</p>
      <div id="color-picker" class="grid grid-cols-6 gap-2 not-prose">
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="red"     aria-label="Red"     title="Red"     style="background:#dc2626;--i:0"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="orange"  aria-label="Orange"  title="Orange"  style="background:#ea580c;--i:1"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="amber"   aria-label="Amber"   title="Amber"   style="background:#b45309;--i:2"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="yellow"  aria-label="Yellow"  title="Yellow"  style="background:#ca8a04;--i:3"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="lime"    aria-label="Lime"    title="Lime"    style="background:#4d7c0f;--i:4"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="green"   aria-label="Green"   title="Green"   style="background:#15803d;--i:5"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="emerald" aria-label="Emerald" title="Emerald" style="background:#059669;--i:6"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="teal"    aria-label="Teal"    title="Teal"    style="background:#0f766e;--i:7"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="cyan"    aria-label="Cyan"    title="Cyan"    style="background:#0e7490;--i:8"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="sky"     aria-label="Sky"     title="Sky"     style="background:#0284c7;--i:9"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="blue"    aria-label="Blue"    title="Blue"    style="background:#2563eb;--i:10"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="indigo"  aria-label="Indigo"  title="Indigo"  style="background:#4f46e5;--i:11"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="violet"  aria-label="Violet"  title="Violet"  style="background:#7c3aed;--i:12"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="purple"  aria-label="Purple"  title="Purple"  style="background:#9333ea;--i:13"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="fuchsia" aria-label="Fuchsia" title="Fuchsia" style="background:#c026d3;--i:14"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="pink"    aria-label="Pink"    title="Pink"    style="background:#db2777;--i:15"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="rose"    aria-label="Rose"    title="Rose"    style="background:#e11d48;--i:16"></button>
        <button type="button" class="enrollment-color-option h-12 w-full rounded-xl border-2 border-transparent shadow-sm" data-theme-color="slate"   aria-label="Slate"   title="Slate"   style="background:#475569;--i:17"></button>
      </div>
      <p id="enroll-error" class="mt-2 text-red-500 text-sm hidden">Something went wrong. Please try again.</p>
    </div>
  </div>

  <!-- Orientation content (always visible) -->
  <div class="prose dark:prose-invert max-w-none">
    <h2>What is OpenCode?</h2>

    <p>
      <a href="https://opencode.ai">OpenCode</a> is a free, open-source AI coding agent that you install on your personal computer. The primary interface is a chat window, much like ChatGPT or Claude, where you have a back and forth dialogue with an AI model. But instead of just chatting, OpenCode can read and write files on your computer, write code, run commands, and interact with other applications.
    </p>

    <p>
      Despite the name, OpenCode is not just a tool for writing software. You can use it to automate any task on your computer, from managing files to controlling other applications. It's like having an assistant that can understand your intentions, help you brainstorm, do deep research, and build creative things.
    </p>

    <p>Unlike proprietary tools like Claude Code and OpenAI Codex, OpenCode works with <a href="https://opencode.ai/docs/providers/">75+ AI model providers</a>, including <a href="https://anthropic.com">Anthropic</a> (Claude), <a href="https://openai.com">OpenAI</a> (GPT), and <a href="https://deepmind.google/technologies/gemini/">Google</a> (Gemini). You can also run open-source models locally on your own machine using tools like <a href="https://ollama.com">Ollama</a>, <a href="https://lmstudio.ai">LM Studio</a>, or <a href="https://github.com/ggml-org/llama.cpp">llama.cpp</a> — no cloud account needed.</p>

    <h2>Who is this for?</h2>

    <p>
      This course is for anyone who wants to expand their creative potential with AI. Whether you're a student, a hobbyist, a professional developer, or just curious about AI, OpenCode can help you do more with less effort.
    </p>

    <p>
      This course is for <strong>beginners</strong> who are new to AI coding agents. You don't need to be a programmer, and you don't need any experience with the terminal. We'll be using the OpenCode Desktop app, which provides a familiar graphical interface.
    </p>

    <p>
      This course is also for <strong>experienced developers</strong>. It'll get you set up with a good foundation for using OpenCode effectively, and you'll learn some tips and tricks for getting the most out of it.
    </p>

    <h2>What you'll learn</h2>

    <p>By the end of this course, you'll know how to:</p>

    <ul>
      <li>Install and configure OpenCode</li>
      <li>Use AI models to help you write and edit code</li>
      <li>Control what OpenCode can and can't do on your machine</li>
      <li>Connect external tools and services</li>
      <li>Run multiple sessions in parallel</li>
      <li>Build websites, games, and other creative projects!</li>
    </ul>

    <h2>How it works</h2>

    <p>Work through the lessons in order. Each one builds on the previous. Some lessons involve pasting prompts into OpenCode and letting it do the work for you. Progress is tracked through the website and synced with your OpenCode app.</p>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>

  <script is:inline>
    (function() {
      var idCard          = document.getElementById("student-id-card");
      var pageHeader      = document.getElementById("page-header");
      var stepButton      = document.getElementById("enroll-step-button");
      var stepColor       = document.getElementById("enroll-step-color");
      var enrollBtn       = document.getElementById("enroll-button");
      var colorPickerCopy = document.getElementById("color-picker-copy");
      var enrollError     = document.getElementById("enroll-error");
      var display         = document.getElementById("student-id-display");
      var notEnrolledSection = document.getElementById("not-enrolled-section");
      var enrolledSection    = document.getElementById("enrolled-section");

      var colorOptions = Array.prototype.slice.call(
        document.querySelectorAll(".enrollment-color-option[data-theme-color]")
      );

      var selectedTheme = window.school.getThemeColor();
      var isSubmitting = false;

      var chars  = "abcdefghijklmnopqrstuvwxyz";
      var digits = "0123456789";

      function randomChar(real) {
        if (real === "-") return "-";
        if (real >= "0" && real <= "9") return digits[Math.floor(Math.random() * digits.length)];
        return chars[Math.floor(Math.random() * chars.length)];
      }

      function scramble(target) {
        var result = "";
        for (var i = 0; i < target.length; i++) result += randomChar(target[i]);
        return result;
      }

      function fireConfetti() {
        var duration = 4500;
        var end = Date.now() + duration;
        var palettes = window.school.getThemePalettes();
        var palette = palettes[window.school.getThemeColor()] || palettes.blue;
        var colors = [palette.solid, palette.solidHover, palette.linkDark, palette.softText, palette.softTextDark];

        (function frame() {
          // Top-left → center
          window.confetti({ particleCount: 10, angle: 315,  spread: 70, startVelocity: 55, gravity: 0.8, origin: { x: 0, y: 0 }, colors: colors });
          // Top-right → center
          window.confetti({ particleCount: 10, angle: 225, spread: 70, startVelocity: 55, gravity: 0.8, origin: { x: 1, y: 0 }, colors: colors });
          // Bottom-left → center
          window.confetti({ particleCount: 10, angle: 45,  spread: 70, startVelocity: 55, gravity: 0.8, origin: { x: 0, y: 1 }, colors: colors });
          // Bottom-right → center
          window.confetti({ particleCount: 10, angle: 135, spread: 70, startVelocity: 55, gravity: 0.8, origin: { x: 1, y: 1 }, colors: colors });
          if (Date.now() < end) requestAnimationFrame(frame);
        })();
      }

      function cipherReveal(target, callback) {
        var resolved = 0;
        display.textContent = scramble(target);

        var scrambleInterval = setInterval(function() {
          var next = "";
          for (var i = 0; i < target.length; i++) {
            if (i < resolved)           next += target[i];
            else if (target[i] === "-") next += "-";
            else                        next += randomChar(target[i]);
          }
          display.textContent = next;
        }, 30);

        setTimeout(function() {
          var resolveInterval = setInterval(function() {
            if (resolved >= target.length) {
              clearInterval(scrambleInterval);
              clearInterval(resolveInterval);
              display.textContent = target;
              if (callback) callback();
              return;
            }
            if (target[resolved] === "-") resolved++;
            resolved++;
          }, 140);
        }, 600);
      }

      function revealIdCard(studentId) {
        display.textContent = studentId;
        idCard.classList.remove("hidden");
        pageHeader.classList.add("hidden");
      }

      function showEnrolled(studentId, animate) {
        notEnrolledSection.classList.add("hidden");
        enrolledSection.classList.remove("hidden");
        pageHeader.classList.add("hidden");
        display.textContent = studentId;
        idCard.classList.remove("hidden");

        if (animate) {
          // Re-run cipher reveal on the card at top
          cipherReveal(studentId, function() {
            fireConfetti();
            window.school.markComplete("enrollment").then(function() {
              window.school.updateAllCheckmarks();
              if (typeof window.school.updateEnrolledIndicator === "function") {
                window.school.updateEnrolledIndicator();
              }
            });
          });
        }
      }

      function setSelectedTheme(themeName) {
        selectedTheme = window.school.setThemeColor(themeName);
        colorOptions.forEach(function(opt) {
          var isSelected = opt.getAttribute("data-theme-color") === selectedTheme;
          opt.style.outline = isSelected ? "2px solid var(--theme-solid)" : "none";
          opt.style.outlineOffset = "2px";
        });
      }

      function setPickerState(message, disabled) {
        if (colorPickerCopy && message) colorPickerCopy.textContent = message;
        colorOptions.forEach(function(opt) {
          opt.disabled = disabled;
          opt.classList.toggle("opacity-60", disabled);
          opt.classList.toggle("cursor-not-allowed", disabled);
        });
      }

      // On page load: if already enrolled, show card + lesson list
      var existingId = window.school.getStudentId();
      if (existingId) {
        showEnrolled(existingId, false);
      } else {
        setSelectedTheme(selectedTheme);
      }

      // Step 1: click Enroll button → show color picker with staggered animation
      if (enrollBtn) {
        enrollBtn.addEventListener("click", function() {
          stepButton.classList.add("hidden");
          stepColor.classList.remove("hidden");
          setSelectedTheme(selectedTheme);
          // Trigger entrance animation on each swatch
          colorOptions.forEach(function(opt) {
            opt.classList.remove("swatch-animate");
            // Force reflow so re-adding the class replays the animation
            void opt.offsetWidth;
            opt.classList.add("swatch-animate");
          });
        });
      }

      // Step 2: click a color → enroll + animate
      colorOptions.forEach(function(opt) {
        opt.addEventListener("click", async function() {
          if (isSubmitting) return;
          isSubmitting = true;
          enrollError.classList.add("hidden");
          setSelectedTheme(opt.getAttribute("data-theme-color"));
          setPickerState("Generating your student ID...", true);
          try {
            var data = await window.school.enroll();
            showEnrolled(data.studentId, true);
          } catch (e) {
            enrollError.classList.remove("hidden");
            setPickerState("Choose a color for your student ID card and site theme.", false);
            isSubmitting = false;
          }
        });
      });
    })();
  </script>
</Base>
