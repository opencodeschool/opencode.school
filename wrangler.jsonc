{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "opencodeschool",
  "compatibility_date": "2026-03-12",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist"
  },
  "kv_namespaces": [
    {
      "binding": "PROGRESS",
      "id": "3bd04cd0e35548b181036e6385b5120c"
    }
  ],
  "routes": [
    {
      "pattern": "opencode.school",
      "custom_domain": true
    }
  ]
}
